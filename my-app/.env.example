# Frontend Environment Variables
# Copy this file to .env.local and update values

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mri-app?retryWrites=true&w=majority

# Backend API URL (your Render deployment URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production, use your Render backend URL:
# NEXT_PUBLIC_API_URL=https://mri-preprocessing-api.onrender.com
